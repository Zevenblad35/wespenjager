---
const pages = [
  { url: '/', priority: '1.0', changefreq: 'weekly' },
  { url: '/wespennest-verwijderen', priority: '0.9', changefreq: 'monthly' },
  { url: '/wespenbestrijding', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespenval-plaatsen', priority: '0.7', changefreq: 'monthly' },
  { url: '/wespen-voorkomen', priority: '0.7', changefreq: 'monthly' },
  { url: '/wespen', priority: '0.8', changefreq: 'monthly' },
  { url: '/veelgestelde-vragen', priority: '0.8', changefreq: 'monthly' },
  { url: '/over-ons', priority: '0.7', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-enschede', priority: '0.9', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-hengelo', priority: '0.9', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-almelo', priority: '0.9', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-deventer', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-zwolle', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-oldenzaal', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-borne', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-rijssen', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-nijverdal', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-hellendoorn', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-wierden', priority: '0.8', changefreq: 'monthly' },
  { url: '/wespennest-verwijderen-delden', priority: '0.7', changefreq: 'monthly' },
];

const baseUrl = 'https://wespenjager.nl';
const now = new Date().toISOString().split('T')[0];
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {pages.map(p => (
    <url>
      <loc>{baseUrl}{p.url}</loc>
      <lastmod>{now}</lastmod>
      <changefreq>{p.changefreq}</changefreq>
      <priority>{p.priority}</priority>
    </url>
  ))}
</urlset>
