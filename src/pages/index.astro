---
import Base from '../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Wespennest verwijderen",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Wespenfixer.nl - Koster Bestrijdingstechniek"
  },
  "areaServed": "Twente, Overijssel",
  "description": "Professioneel wespennest verwijderen door erkend bestrijdingstechnicus. Dezelfde dag service mogelijk in heel Twente en Overijssel.",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Hoe snel kan een wespennest worden verwijderd?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In de meeste gevallen is dezelfde dag service mogelijk. Bel 's ochtends en Joost is er vaak nog die dag."
      }
    },
    {
      "@type": "Question",
      "name": "Wat kost een wespennest laten verwijderen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "De prijs hangt af van de locatie en grootte van het nest. Bel voor een vrijblijvende offerte."
      }
    },
    {
      "@type": "Question",
      "name": "Is wespenbestrijding gevaarlijk?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Voor een leek wel — wespen worden erg agressief als hun nest wordt bedreigd. Joost werkt met professionele beschermende uitrusting en middelen."
      }
    }
  ]
};
---

<Base
  title="Wespennest laten verwijderen? | Wespenfixer.nl – Twente & Overijssel"
  description="Last van een wespennest? Joost van Wespenfixer.nl verwijdert wespen snel, veilig en professioneel. Werkzaam in heel Twente en Overijssel. App direct voor zelfde dag service."
  schema={faqSchema}
>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <img src="/images/joost-behandeling.jpg" alt="Joost behandelt wespennest in professioneel pak" class="hero-img" />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content container">
    <div class="hero-text">
      <span class="eyebrow text-yellow">Erkend bestrijdingstechnicus · Twente & Overijssel</span>
      <h1 class="hero-title">
        Wespennest<br>
        <span class="text-yellow">verwijderen?</span><br>
        App de Fixer.
      </h1>
      <p class="lead" style="color: rgba(255,255,255,0.85); margin: 24px 0;">
        Joost helpt u snel en veilig van wespen af — dezelfde dag service mogelijk. Koster Bestrijdingstechniek, actief in heel Twente en Overijssel.
      </p>
      <div class="hero-ctas">
        <a href="https://wa.me/31683392065" target="_blank" rel="noopener" class="btn btn-wa btn-hero">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp: 06 83392065
        </a>
        <a href="/afspraak" class="btn btn-outline">📅 Afspraak inplannen</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <span class="stars">★★★★★</span>
          <span>4.9 op Google</span>
        </div>
        <div class="trust-sep">·</div>
        <div class="trust-item">⚡ Dezelfde dag</div>
        <div class="trust-sep">·</div>
        <div class="trust-item">🛡️ Gecertificeerd</div>
      </div>
    </div>
  </div>
  <div class="wasp-stripe"></div>
</section>

<!-- URGENCY BAR -->
<section class="urgency-bar">
  <div class="container">
    <div class="urgency-inner">
      <span class="urgency-icon">⚠️</span>
      <strong>Wespenplaagseizoeen: mei t/m oktober</strong>
      <span class="urgency-sep">—</span>
      <span>Wespen zijn nu extra actief. Wacht niet te lang — een nest groeit elke dag.</span>
      <a href="https://wa.me/31683392065" class="btn btn-primary urgency-btn">WhatsApp nu</a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" id="diensten">
  <div class="container">
    <div class="section-header text-center">
      <span class="eyebrow">Wat doet Joost voor u</span>
      <h2>Professionele wespenoplossingen</h2>
      <p class="lead" style="margin: 16px auto; text-align: center;">Van eenmalig wespennest verwijderen tot preventieve wespenbestrijding — voor particulieren in heel Twente.</p>
    </div>
    <div class="grid-2" style="margin-top: 48px; gap: 24px;">
      <a href="/wespennest-verwijderen" class="service-card">
        <div class="service-card-icon">🪺</div>
        <div class="service-card-body">
          <span class="badge">Meest gevraagd</span>
          <h3>Wespennest verwijderen</h3>
          <p>Het wespennest wordt professioneel verwijderd of behandeld. Joost werkt met gecertificeerde middelen en beschermende uitrusting.</p>
          <span class="service-link">Meer info →</span>
        </div>
      </a>
      <a href="/wespenbestrijding" class="service-card">
        <div class="service-card-icon">💨</div>
        <div class="service-card-body">
          <h3>Wespenbestrijding</h3>
          <p>Aanhoudende overlast of meerdere nesten? Joost doet een grondige inspectie en bestrijdt de wespen professioneel.</p>
          <span class="service-link">Meer info →</span>
        </div>
      </a>
      <a href="/wespenval-plaatsen" class="service-card">
        <div class="service-card-icon">🟡</div>
        <div class="service-card-body">
          <h3>Wespenval plaatsen</h3>
          <p>Preventief een wespenval laten plaatsen zodat uw tuin wespenvrij blijft. Effectief en veilig voor het gezin.</p>
          <span class="service-link">Meer info →</span>
        </div>
      </a>
      <a href="/wespen-voorkomen" class="service-card">
        <div class="service-card-icon">🛡️</div>
        <div class="service-card-body">
          <h3>Wespen voorkomen</h3>
          <p>Advies en preventieve maatregelen zodat wespen niet meer terugkomen. Joost geeft eerlijk advies zonder extra verkoop.</p>
          <span class="service-link">Meer info →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- HOE WERKT HET -->
<section class="section section-dark" id="werkwijze">
  <div class="container">
    <div class="section-header text-center">
      <span class="eyebrow" style="color: var(--yellow);">Zo simpel werkt het</span>
      <h2 class="text-white">Van app tot wespenvrij</h2>
    </div>
    <div class="steps" style="margin-top: 56px;">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-content">
          <h3 class="text-yellow">Bel of app Joost</h3>
          <p>App Joost op 06 83392065. Joost reageert snel en plannen de afspraak in — vaak al dezelfde dag.</p>
        </div>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-content">
          <h3 class="text-yellow">Inspectie ter plekke</h3>
          <p>Joost beoordeelt het nest, de locatie en de ernst van de overlast. Hij legt uit wat de beste aanpak is.</p>
        </div>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-content">
          <h3 class="text-yellow">Behandeling & advies</h3>
          <p>Met de juiste middelen en beschermende uitrusting verwijdert Joost het wespennest. U krijgt daarna advies om herhaling te voorkomen.</p>
        </div>
      </div>
    </div>
    <div class="text-center" style="margin-top: 48px;">
      <a href="https://wa.me/31683392065" class="btn btn-primary">📅 Afspraak inplannen</a>
    </div>
  </div>
</section>

<!-- JOOST + FOTO -->
<section class="section">
  <div class="container">
    <div class="about-split">
      <div class="about-img-wrap">
        <img src="/images/joost-ladder.jpg" alt="Joost Koster — wespenbestrijder Twente" class="about-img" />
        <div class="about-badge">
          <span class="about-badge-num">10+</span>
          <span>jaar ervaring</span>
        </div>
      </div>
      <div class="about-text">
        <span class="eyebrow">Wie is Joost?</span>
        <h2>Vakman met hart voor zijn werk</h2>
        <p class="lead">Joost is erkend bestrijdingstechnicus bij Koster Bestrijdingstechniek. Hij helpt particulieren in Twente en Overijssel snel en veilig van wespenplaag af — zonder gedoe.</p>
        <ul class="about-list">
          <li>✅ Gecertificeerd bestrijdingstechnicus</li>
          <li>✅ Werkt met professionele beschermingsuitrusting</li>
          <li>✅ Erkende en veilige bestrijdingsmiddelen</li>
          <li>✅ Eerlijk advies zonder onnodige extra's</li>
          <li>✅ Dezelfde dag service mogelijk</li>
        </ul>
        <a href="/over-ons" class="btn btn-blue" style="margin-top: 24px;">Over Joost</a>
      </div>
    </div>
  </div>
</section>

<!-- WERKGEBIED -->
<section class="section section-grey">
  <div class="container">
    <div class="section-header text-center">
      <span class="eyebrow">Werkgebied</span>
      <h2>Actief in heel Twente & Overijssel</h2>
      <p class="lead" style="margin: 16px auto; text-align: center;">Woon je in een van deze steden? Joost is er snel bij.</p>
    </div>
    <div class="location-grid" style="margin-top: 40px;">
