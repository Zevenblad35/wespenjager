<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    background: var(--black);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.45;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.85) 40%, rgba(26,111,191,0.3) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    padding: 80px 24px;
  }
  .hero-text { max-width: 640px; }
  .hero-title {
    margin: 16px 0;
    line-height: 1.0;
    font-size: clamp(2.8rem, 6vw, 5rem);
    color: var(--white);
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .btn-hero {
    font-size: 1.05rem;
    padding: 16px 32px;
    box-shadow: 0 4px 24px rgba(245,196,0,0.4);
  }
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .trust-sep { opacity: 0.3; }
  .trust-item { display: flex; align-items: center; gap: 6px; }

  /* URGENCY */
  .urgency-bar {
    background: #1A1A1A;
    border-left: 4px solid var(--yellow);
    padding: 16px 0;
  }
  .urgency-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    color: rgba(255,255,255,0.85);
    font-size: 0.92rem;
  }
  .urgency-btn { margin-left: auto; }
  @media (max-width: 640px) { .urgency-btn { width: 100%; text-align: center; } }

  /* SERVICE CARDS */
  .service-card {
    display: flex;
    background: var(--white);
    border: 2px solid #eee;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .service-card:hover {
    border-color: var(--yellow);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .service-card-icon {
    font-size: 2.5rem;
    padding: 28px 20px;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
  }
  .service-card-body { padding: 24px; }
  .service-card-body h3 { margin: 8px 0 8px; }
  .service-card-body p { color: #555; font-size: 0.95rem; margin-bottom: 12px; }
  .service-link {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 900;
    color: var(--blue);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  /* STEPS */
  .steps {
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }
  .step {
    flex: 1;
    text-align: center;
  }
  .step-num {
    width: 56px;
    height: 56px;
    background: var(--yellow);
    color: var(--black);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }
  .step-content p { color: rgba(255,255,255,0.7); margin-top: 8px; font-size: 0.95rem; }
  .step-arrow {
    font-size: 2rem;
    color: var(--yellow);
