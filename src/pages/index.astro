        { city: 'Zuna', url: '/wespennest-verwijderen-zuna' },
        { city: 'Wierden', url: '/wespennest-verwijderen-wierden' },
        { city: 'Notter', url: '/wespennest-verwijderen-notter' },
        { city: 'Ommen', url: '/wespennest-verwijderen-ommen' },
