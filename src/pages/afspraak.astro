---
import Base from '../layouts/Base.astro';
---

<Base
  title="Afspraak inplannen | Wespenfixer.nl"
  description="Plan een afspraak in met Joost van Wespenfixer.nl voor professionele wespenbestrijding in Twente en Overijssel."
  canonical="https://wespenfixer.nl/afspraak"
>

<section class="page-hero">
  <div class="container">
    <span class="eyebrow">Afspraak maken</span>
    <h1>Plan een <span class="text-yellow">afspraak</span> in</h1>
    <p class="lead">Vul het formulier in en Joost neemt zo snel mogelijk contact op — meestal dezelfde dag nog.</p>
  </div>
</section>
<div class="wasp-stripe"></div>

<section class="section">
  <div class="container">
    <div class="afspraak-wrap">

      <!-- Placeholder: formulier komt hier -->
      <div class="form-placeholder">
        <div class="form-placeholder-inner">
          <span class="placeholder-icon">📅</span>
          <h2>Afspraakformulier</h2>
          <p>Het afspraakformulier wordt binnenkort beschikbaar gesteld. In de tussentijd kunt u direct contact opnemen via WhatsApp.</p>
          <a
            href="https://wa.me/31683392065"
            target="_blank"
            rel="noopener"
            class="btn btn-wa"
