            06 83392065
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  .page-hero {
    background: var(--black);
    color: var(--white);
    padding: 72px 0 56px;
  }
  .page-hero .eyebrow { color: var(--yellow); }
  .page-hero h1 { color: var(--white); margin: 12px 0 16px; }
  .page-hero .lead { color: rgba(255,255,255,0.8); }

  .afspraak-wrap {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    align-items: start;
  }

  .form-placeholder {
    border: 2px dashed #ddd;
    border-radius: var(--radius-lg);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--grey);
  }
  .form-placeholder-inner {
    text-align: center;
    padding: 48px 32px;
  }
  .placeholder-icon { font-size: 3rem; display: block; margin-bottom: 16px; }
  .form-placeholder-inner h2 { margin-bottom: 16px; }
  .form-placeholder-inner p { color: #666; max-width: 380px; margin: 0 auto 28px; }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: var(--white);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: var(--radius);
    transition: background 0.18s, transform 0.18s;
  }
  .btn-wa:hover { background: #1ebe5d; transform: translateY(-2px); }

  .afspraak-aside { display: flex; flex-direction: column; gap: 20px; }
  .aside-info {
    background: var(--grey);
    border-radius: var(--radius-lg);
    padding: 24px;
  }
  .aside-info h3 { margin-bottom: 16px; font-size: 1rem; }
  .aside-info ul { list-style: none; }
  .aside-info li { padding: 8px 0; border-bottom: 1px solid #e5e5e5; font-size: 0.9rem; }

  .aside-wa {
    background: var(--black);
    border-radius: var(--radius-lg);
    padding: 20px;
  }
  .aside-wa p { color: rgba(255,255,255,0.7); font-size: 0.9rem; margin-bottom: 12px; }

  @media (max-width: 700px) {
    .afspraak-wrap { grid-template-columns: 1fr; }
  }
</style>
